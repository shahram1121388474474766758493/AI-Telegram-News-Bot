# ==========================================================
# AI-Telegram-News-Bot — Environment Configuration Template
# ----------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# NEVER commit your real `.env` — only this `.env.example` is tracked.
# ==========================================================

# ---- Runtime ----
# development | production
ENVIRONMENT=development
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Telegram ----
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here
# Target channel: @username or numeric -100... id. Bot must be an admin of it.
TELEGRAM_CHANNEL_ID=@your_channel
# Comma-separated Telegram user IDs allowed to run admin commands
ADMIN_USER_IDS=111111111,222222222

# ---- Database ----
# Dev (SQLite):     sqlite:///data/newsbot.db
# Prod (PostgreSQL): postgresql+psycopg://user:pass@host:5432/newsbot
DATABASE_URL=sqlite:///data/newsbot.db

# ---- AI / LLM (importance scoring + rewriting) ----
# OpenAI-compatible provider (provider-agnostic client)
LLM_API_KEY=sk-your-llm-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- Image generation / search ----
IMAGE_API_KEY=your-image-provider-key
IMAGE_BASE_URL=https://api.your-image-provider.com

# ---- Publishing behavior ----
# Minimum minutes between two consecutive posts
MIN_POST_GAP_MINUTES=20
# Publish only articles with an AI importance score >= this (0.0 - 1.0)
IMPORTANCE_THRESHOLD=0.6
# How often to poll sources for new items (minutes)
POLL_INTERVAL_MINUTES=10
# Safety valve: maximum posts per day (0 = unlimited)
MAX_POSTS_PER_DAY=0

# ---- Cost controls (optional) ----
# Approximate maximum LLM spend per day in your currency units (0 = unlimited)
MAX_AI_SPEND_PER_DAY=0

# ---- Deduplication thresholds (optional; sensible defaults in code) ----
# SimHash Hamming distance below which items are treated as near-duplicates
DEDUP_SIMHASH_MAX_DISTANCE=3
# rapidfuzz title similarity (0-100) above which items are near-duplicates
DEDUP_TITLE_FUZZ_MIN=90
